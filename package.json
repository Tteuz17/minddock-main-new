{
  "name": "minddock",
  "displayName": "MindDock — NotebookLM Supercharged",
  "version": "0.1.0",
  "description": "Transforma o Google NotebookLM num centro de conhecimento completo com importação de IA, Zettelkasten e Prompts Ágeis.",
  "private": true,
  "scripts": {
    "dev": "node --no-deprecation ./node_modules/plasmo/bin/index.mjs dev",
    "build": "node --no-deprecation ./node_modules/plasmo/bin/index.mjs build",
    "package": "node --no-deprecation ./node_modules/plasmo/bin/index.mjs package",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run type-check && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-context-menu": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "fflate": "^0.8.2",
    "framer-motion": "^11.11.7",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.453.0",
    "plasmo": "^0.90.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "vis-network": "^9.1.9"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.3.1",
    "@types/chrome": "^0.0.277",
    "@types/node": "^22.19.13",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.9.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "identity",
      "downloads",
      "activeTab",
      "tabs",
      "scripting",
      "contextMenus",
      "webRequest",
      "alarms",
      "sidePanel",
      "notifications"
    ],
    "host_permissions": [
      "https://notebooklm.google.com/*",
      "https://*.supabase.co/*",
      "https://docs.google.com/*",
      "https://chat.openai.com/*",
      "https://chatgpt.com/*",
      "https://claude.ai/*",
      "https://gemini.google.com/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "web_accessible_resources": [
      {
        "resources": [
          "assets/icon-*.png"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ]
  }
}
