# Copy this file to .env and fill in your values.
# NEVER commit .env â€” it is git-ignored.

# Supabase project credentials (public â€” safe to expose in extension bundle)
PLASMO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PLASMO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI/Notion backend endpoints (recommended for production)
PLASMO_PUBLIC_AI_PROXY_ENDPOINT=https://your-project.supabase.co/functions/v1/ai-proxy
# Optional: override Notion OAuth exchange endpoint.
# If omitted, extension auto-uses: ${PLASMO_PUBLIC_SUPABASE_URL}/functions/v1/notion-oauth-exchange
PLASMO_PUBLIC_NOTION_OAUTH_EXCHANGE_ENDPOINT=https://your-project.supabase.co/functions/v1/notion-oauth-exchange
# Optional hardening for Edge Functions:
# ALLOWED_ORIGINS=https://minddocklm.digital,https://app.minddocklm.digital
# NOTION_ALLOWED_EXTENSION_IDS=<chrome_extension_id_32_chars>

# Stripe
PLASMO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_xxx
STRIPE_SECRET_KEY=sk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_THINKER_MONTHLY=price_xxx
STRIPE_PRICE_THINKER_YEARLY=price_xxx
# Optional (if Thinker Pro is enabled):
STRIPE_PRICE_THINKER_PRO_MONTHLY=price_xxx
STRIPE_PRICE_THINKER_PRO_YEARLY=price_xxx

# Network Manager (external RPC + telemetry)
PLASMO_PUBLIC_EXTERNAL_EXPORT_RPC_ENDPOINT=https://api.nosso-saas.com/v1/rpc/export
PLASMO_PUBLIC_TELEMETRY_ERRORS_ENDPOINT=https://api.nosso-saas.com/v1/telemetry/errors

# Claude API key must NOT go here.
# Store it as a Supabase secret so it never reaches the extension bundle:
#   supabase secrets set CLAUDE_API_KEY=<your-claude-api-key>
