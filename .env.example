# Copy this file to .env and fill in your values.
# NEVER commit .env — it is git-ignored.

# Supabase project credentials (public — safe to expose in extension bundle)
PLASMO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PLASMO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe
PLASMO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Notion OAuth (Client ID fixado no codigo; mantenha apenas o secret no env)
PLASMO_PUBLIC_NOTION_CLIENT_SECRET=COLE_O_SEU_SECRET_AQUI

# Claude API key must NOT go here.
# Store it as a Supabase secret so it never reaches the extension bundle:
#   supabase secrets set CLAUDE_API_KEY=sk-ant-...
