# Supabase
PLASMO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PLASMO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI/Notion backend endpoints (recommended for production)
PLASMO_PUBLIC_AI_PROXY_ENDPOINT=https://your-project.supabase.co/functions/v1/ai-proxy
# Optional: override Notion OAuth exchange endpoint.
# If omitted, extension auto-uses: ${PLASMO_PUBLIC_SUPABASE_URL}/functions/v1/notion-oauth-exchange
PLASMO_PUBLIC_NOTION_OAUTH_EXCHANGE_ENDPOINT=https://your-project.supabase.co/functions/v1/notion-oauth-exchange

# Stripe
PLASMO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Network Manager (external RPC + telemetry)
PLASMO_PUBLIC_EXTERNAL_EXPORT_RPC_ENDPOINT=https://api.nosso-saas.com/v1/rpc/export
PLASMO_PUBLIC_TELEMETRY_ERRORS_ENDPOINT=https://api.nosso-saas.com/v1/telemetry/errors
